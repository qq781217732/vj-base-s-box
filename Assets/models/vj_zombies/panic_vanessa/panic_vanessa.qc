{
	is_rigid
	{
		length 15
		tip_mass 100
		pitch_constraint -10 10
		pitch_friction 0
		pitch_bounce 0
		yaw_constraint -10 10
		yaw_friction 0
		yaw_bounce 0
		angle_constraint 39.999999
