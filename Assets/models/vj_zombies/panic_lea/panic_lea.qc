$jigglebone "hoodie_l"
{
	is_flexible
	{
		length 10
		tip_mass 1
		pitch_stiffness 300
		pitch_damping 10
		yaw_stiffness 300
		yaw_damping 10
		allow_length_flex
		along_stiffness 100
		along_damping 0
		angle_constraint 10
	}
}
$jigglebone "hoodie_c"
{
	is_flexible
	{
		length 10
		tip_mass 1
		pitch_stiffness 300
		pitch_damping 10
		yaw_stiffness 300
		yaw_damping 10
		allow_length_flex
		along_stiffness 100
		along_damping 0
